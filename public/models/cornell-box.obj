# Cornell Box (classic) - simplified single-mesh version
# Units: meters. Origin at box center on floor.
# Room is 2.0 x 2.0 x 2.0 with two inner blocks (short + tall).

# --- Room corners ---
v -1.0  0.0 -1.0
v  1.0  0.0 -1.0
v  1.0  0.0  1.0
v -1.0  0.0  1.0
v -1.0  2.0 -1.0
v  1.0  2.0 -1.0
v  1.0  2.0  1.0
v -1.0  2.0  1.0

# Floor
f 1 2 3 4
# Ceiling
f 8 7 6 5
# Back wall
f 1 5 6 2
# Left wall (red)
f 4 8 5 1
# Right wall (green)
f 2 6 7 3

# --- Short block (right-front) ---
v  0.05 0.0  0.05
v  0.65 0.0 -0.10
v  0.50 0.0  0.65
v -0.10 0.0  0.50
v  0.05 0.60 0.05
v  0.65 0.60 -0.10
v  0.50 0.60 0.65
v -0.10 0.60 0.50
f 9 10 11 12
f 13 16 15 14
f 9 13 14 10
f 10 14 15 11
f 11 15 16 12
f 12 16 13 9

# --- Tall block (left-back) ---
v -0.55 0.0 -0.10
v  0.05 0.0 -0.55
v  0.50 0.0  0.05
v -0.10 0.0  0.50
v -0.55 1.20 -0.10
v  0.05 1.20 -0.55
v  0.50 1.20  0.05
v -0.10 1.20  0.50
f 17 18 19 20
f 21 24 23 22
